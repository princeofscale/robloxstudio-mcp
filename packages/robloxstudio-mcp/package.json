{
  "name": "@princeofscale/robloxstudio-mcp",
  "version": "2.20.1",
  "description": "Free, open-source MCP server for AI agents (Claude Code, Codex, Cursor, Gemini) to operate Roblox Studio — inspect, edit, debug, and automate places locally.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "robloxstudio-mcp": "dist/index.js"
  },
  "files": [
    "dist/**/*",
    "studio-plugin/**/*"
  ],
  "scripts": {
    "build": "tsup",
    "prepack": "node ../../scripts/prepack.mjs",
    "postpack": "node ../../scripts/postpack.mjs"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "roblox",
    "roblox-studio",
    "model-context-protocol",
    "claude-code",
    "codex",
    "cursor",
    "gemini",
    "ai-agent",
    "ai-coding",
    "luau",
    "roblox-plugin",
    "game-development",
    "automation",
    "open-source",
    "developer-tools"
  ],
  "author": "",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/princeofscale/robloxstudio-mcp.git"
  },
  "homepage": "https://github.com/princeofscale/robloxstudio-mcp#readme",
  "bugs": {
    "url": "https://github.com/princeofscale/robloxstudio-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cors": "^2.8.5",
    "express": "^4.22.2",
    "node-fetch": "^3.3.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@princeofscale/robloxstudio-mcp-core": "*"
  }
}
